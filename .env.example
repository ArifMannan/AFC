# Copy to .env locally, or set these in Vercel → Project → Settings → Environment Variables

# App URL (required for NextAuth on Vercel — use your production domain)
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate_a_long_random_string

# MySQL (cPanel remote database — enable Remote MySQL and allow Vercel IPs)
DB_HOST=your-cpanel-mysql-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=futanta_club

# Optional: override API base (leave unset on Vercel to use same-origin /api)
# NEXT_PUBLIC_API_BASE_URL=/api

# Cloudinary (add when ready — uploads on Vercel require this)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_FOLDER=afc-profiles
